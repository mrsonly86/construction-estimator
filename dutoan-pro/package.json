{
  "name": "dutoan-pro",
  "version": "0.1.0",
  "private": true,
  "main": "build/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:main\" \"npm:dev:renderer\"",
    "dev:main": "node --loader ts-node/esm src/main.ts",
    "dev:renderer": "vite",
    "build": "npm run build:renderer && tsc -p tsconfig.main.json && npm run build:copy",
    "build:copy": "cp src/preload.cjs build/",
    "build:renderer": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "electron": "28.2.3"
  },
  "devDependencies": {
    "@types/node": "20.12.12",
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.22",
    "@vitejs/plugin-react": "4.3.1",
    "concurrently": "8.2.2",
    "electron-builder": "24.13.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "ts-node": "10.9.2",
    "tslib": "2.6.3",
    "typescript": "5.5.4",
    "vite": "5.3.1"
  }
}