<!-- MainWindow.xaml - WPF Main Window Template -->
<Window x:Class="ConstructionEstimator.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phần mềm Dự toán Xây dựng Việt Nam" 
        Height="768" 
        Width="1024"
        WindowState="Maximized">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="Dự án">
                <MenuItem Header="Tạo mới" Command="{Binding CreateProjectCommand}"/>
                <MenuItem Header="Mở" Command="{Binding OpenProjectCommand}"/>
                <MenuItem Header="Lưu" Command="{Binding SaveProjectCommand}"/>
                <Separator/>
                <MenuItem Header="Thoát" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="Dự toán">
                <MenuItem Header="Thêm hạng mục" Command="{Binding AddSectionCommand}"/>
                <MenuItem Header="Thêm công việc" Command="{Binding AddItemCommand}"/>
                <MenuItem Header="Tính toán" Command="{Binding CalculateCommand}"/>
            </MenuItem>
            <MenuItem Header="Báo cáo">
                <MenuItem Header="Xem báo cáo" Command="{Binding ViewReportCommand}"/>
                <MenuItem Header="Xuất Excel" Command="{Binding ExportExcelCommand}"/>
                <MenuItem Header="Xuất PDF" Command="{Binding ExportPdfCommand}"/>
            </MenuItem>
        </Menu>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Project Explorer -->
            <TreeView Grid.Column="0" ItemsSource="{Binding Projects}">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Sections}">
                        <TextBlock Text="{Binding Name}"/>
                        <HierarchicalDataTemplate.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Items}">
                                <TextBlock Text="{Binding Name}"/>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </HierarchicalDataTemplate.ItemTemplate>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>
            
            <!-- Main Work Area -->
            <TabControl Grid.Column="2">
                <TabItem Header="Thông tin dự án">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Label Grid.Row="0" Grid.Column="0" Content="Tên dự án:"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedProject.Name}"/>
                        
                        <Label Grid.Row="1" Grid.Column="0" Content="Khách hàng:"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedProject.Client}"/>
                        
                        <Label Grid.Row="2" Grid.Column="0" Content="Địa điểm:"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectedProject.Location}"/>
                        
                        <Label Grid.Row="3" Grid.Column="0" Content="Mô tả:"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SelectedProject.Description}" 
                                 AcceptsReturn="True" Height="60"/>
                        
                        <Label Grid.Row="4" Grid.Column="0" Content="Tổng giá trị:"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SelectedProject.TotalEstimatedCost, StringFormat=N0}" 
                                 IsReadOnly="True" Background="LightGray"/>
                    </Grid>
                </TabItem>
                
                <TabItem Header="Bảng dự toán">
                    <DataGrid ItemsSource="{Binding EstimateItems}" 
                              AutoGenerateColumns="False"
                              CanUserAddRows="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tên công việc" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Đơn vị" Binding="{Binding Unit}" Width="60"/>
                            <DataGridTextColumn Header="Khối lượng" Binding="{Binding Quantity}" Width="80"/>
                            <DataGridTextColumn Header="Vật liệu" Binding="{Binding MaterialCost, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Nhân công" Binding="{Binding LaborCost, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Máy thi công" Binding="{Binding EquipmentCost, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, StringFormat=N0}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Thành tiền" Binding="{Binding TotalCost, StringFormat=N0}" Width="120" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                
                <TabItem Header="Báo cáo">
                    <ScrollViewer>
                        <StackPanel Margin="10">
                            <TextBlock Text="BÁO CÁO DỰ TOÁN XÂY DỰNG" FontSize="16" FontWeight="Bold" TextAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedProject.Name}" FontSize="14" FontWeight="Bold" TextAlignment="Center" Margin="0,5"/>
                            
                            <Grid Margin="0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Thông tin dự án:"/>
                                    <TextBlock Text="{Binding SelectedProject.Client, StringFormat='Khách hàng: {0}'}"/>
                                    <TextBlock Text="{Binding SelectedProject.Location, StringFormat='Địa điểm: {0}'}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Chi phí tổng hợp:"/>
                                    <TextBlock Text="{Binding Report.TotalMaterialCost, StringFormat='Vật liệu: {0:N0} VND'}"/>
                                    <TextBlock Text="{Binding Report.TotalLaborCost, StringFormat='Nhân công: {0:N0} VND'}"/>
                                    <TextBlock Text="{Binding Report.TotalEquipmentCost, StringFormat='Máy thi công: {0:N0} VND'}"/>
                                    <TextBlock Text="{Binding Report.GrandTotal, StringFormat='TỔNG CỘNG: {0:N0} VND'}" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem Content="{Binding StatusMessage}"/>
            <StatusBarItem HorizontalAlignment="Right" Content="{Binding CurrentDateTime}"/>
        </StatusBar>
    </Grid>
</Window>